# Gemini API (required for LLM responses)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Agent configuration
AUTONOMY_LEVEL=0.7
CONFIDENCE_THRESHOLD=0.75
LOG_LEVEL=info

# Interview context
INTERVIEW_ROLE="Software Engineer - Analytical Products"
INTERVIEW_COMPANY="Microsoft"
INTERVIEWERS="P Keerthana,Anitha Sekhar"

# Native agent WebSocket port (must match Jarvis.app)
NATIVE_WS_PORT=8765
