{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist-cli",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/core/**/*",
    "src/config/**/*",
    "src/utils/**/*",
    "src/cli/**/*",
    "src/intent/**/*",
    "src/memory/**/*",
    "src/services/LLMService.ts",
    "src/actions/**/*",
    "src/bridges/**/*",
    "src/analysis/**/*",
    "src/strategy/**/*",
    "src/knowledge/**/*",
    "src/types/index.ts"
  ],
  "exclude": ["node_modules", "dist-cli", "**/*.test.ts"]
}
